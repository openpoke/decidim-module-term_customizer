<% add_decidim_page_title(t("translation_sets.form.title", scope: "decidim.term_customizer.admin")) %>

<div data-controller="accordion">
  <div class="item_show__header">
    <h1 class="item_show__header-title">
      <div>
        <%= t "translation_sets.form.title", scope: "decidim.term_customizer.admin" %>

        <button type="button" data-controls="help-panel" data-open="false" class="label h-6 button button__sm button__transparent-secondary">
          <%= icon "information-line" %>
          <%= t("actions.help", scope: "decidim.term_customizer.admin") %>
        </button>
      </div>
    </h1>
  </div>
  <div class="item__edit item__edit-1col">
    <div class="item__edit-form">
      <%= decidim_form_for(@form, html: { class: "form-defaults form translation-sets-form edit_translation_set translation_set_form_admin" }) do |f| %>
        <%= render partial: "form", object: f, locals: { title: t(".title") } %>

        <div class="item__edit-sticky">
          <div class="item__edit-sticky-container">
            <%= f.submit t(".save"), class: "button button__sm button__secondary" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
