<% add_decidim_page_title(t(".title")) %>

<div data-controller="accordion" id="help-accordion">
  <div class="item_show__header">
    <h1 class="item_show__header-title">
      <div>
        <%= link_to translated_attribute(set.name), translation_set_translations_path(set) %>
        &gt;
        <%= t ".title" %>

        <button type="button" data-controls="help-panel" data-open="false" class="label h-6 button button__sm button__transparent-secondary">
          <%= icon "information-line" %>
          <%= t("actions.help", scope: "decidim.term_customizer.admin") %>
        </button>
      </div>
    </h1>
  </div>
  <div class="item__edit item__edit-1col">
    <div class="item__edit-form">
      <%= decidim_form_for(@form, url: translation_set_translation_path(set, translation), html: { class: "form-defaults form translation-sets-form edit_translation translation_form_admin" }) do |f| %>
        <div id="help-panel" class="callout help-text">
          <p><strong><%= t ".help_title" %></strong></p>
          <%= t ".help_html" %>
          <p><strong><%= t ".term_help_title" %></strong></p>
          <%= t ".term_help_html" %>
        </div>
        <%= render partial: "form", object: f, locals: { title: t(".title") } %>

        <div class="item__edit-sticky">
          <div class="item__edit-sticky-container">
            <%= f.submit t(".save"), class: "button button__sm button__secondary" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
